#include <stdio.h>

#define TAMANHO 10

void bubble_sort(int v[], int tam) {
    int aux;
    // Percorre todos os elementos
    for (int i = 0; i < tam - 1; i++) { 
        // Realiza a comparação e troca (elementos maiores "borbulham" para o final)
        for (int j = 0; j < tam - 1 - i; j++) {
            if (v[j] > v[j + 1]) { // Se o elemento atual for maior que o próximo
                // Troca os elementos
                aux = v[j];
                v[j] = v[j + 1];
                v[j + 1] = aux;
            }
        }
    }
}

int main() {
    int vetor[TAMANHO];
    
    // 1. Leitura do vetor
    printf("Digite %d numeros inteiros:\n", TAMANHO);
    for (int i = 0; i < TAMANHO; i++) {
        printf("Elemento %d: ", i + 1);
        scanf("%d", &vetor[i]);
    }
    
    // 2. Ordenação
    bubble_sort(vetor, TAMANHO); 
    
    // 3. Exibição do vetor ordenado
    printf("\nVetor ordenado de forma crescente:\n");
    for (int i = 0; i < TAMANHO; i++) {
        printf("%d ", vetor[i]);
    }
    printf("\n");
    
    return 0;
}
