#include <stdio.h>

int main() {
    int numero;
    int cont_pares = 0;
    
    printf("Digite 10 numeros inteiros:\n");
    
    for (int i = 0; i < 10; i++) {
        printf("Numero %d: ", i + 1);
        scanf("%d", &numero);
        
        
        if (numero % 2 == 0) {
            cont_pares++; //
        }
    }
    
    printf("\nTotal de numeros pares: %d\n", cont_pares);
    return 0;
}
