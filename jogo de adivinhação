#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
   

  
    int numeroSecreto = (rand() % 100) + 1;
    int palpite;
    int tentativas = 0;
    int acertou = 0;

    printf("*********************************\n");
    printf("* Bem-vindo ao Jogo da Adivinhação! *\n");
    printf("*********************************\n");
    printf("Estou pensando em um número entre 1 e 100.\n");

  
    while (!acertou) {
        printf("Tentativa %d: Digite seu palpite: ", tentativas + 1);
        scanf("%d", &palpite);
        tentativas++;

     
        if (palpite == numeroSecreto) {
            acertou = 1;
        } else if (palpite < numeroSecreto) {
            printf("Seu palpite é **menor** que o número secreto. Tente novamente!\n");
        } else {
            printf("Seu palpite é **maior** que o número secreto. Tente novamente!\n");
        }

        printf("---------------------------------\n");
    }

   
    printf("\n");
    printf(" Parabéns! Você acertou! !!!!\n");
    printf("O número secreto era **%d**.\n", numeroSecreto);
    printf("Você precisou de **%d** tentativas.\n", tentativas);

    return 0;
}
